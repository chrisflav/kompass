#: jdav_web/mailer/admin.py:96
msgid "Send message"
msgstr "Nachricht verschicken"

#: jdav_web/mailer/admin.py:126 jdav_web/mailer/tests/admin.py:197
msgid ""
"Your account is not connected to a member. Please contact your system "
"administrator."
msgstr ""
"Dein Account ist nicht mit eine*r Teilnehmer*in verknüpft. Bitte kontaktiere "
"deine*n Systemadministrator*in."

#: jdav_web/mailer/admin.py:135 jdav_web/mailer/tests/admin.py:218
#, python-format
msgid ""
"Your email address is not an internal email address. Please use an email "
"address with one of the following domains: %(domains)s."
msgstr ""
"Deine E-Mail Adresse ist keine DAV360 E-Mail Adresse. Bitte stelle sicher, "
"dass deine E-Mail Adresse eine der folgenden Domains hat: %(domains)s."

#: jdav_web/mailer/admin.py:142 jdav_web/mailer/tests/admin.py:163
msgid "Failed to send message"
msgstr "Fehler beim Senden der Email"

#: jdav_web/mailer/admin.py:146 jdav_web/mailer/tests/admin.py:180
msgid "Failed to send some messages"
msgstr "Fehler beim Senden der Emails"

#: jdav_web/mailer/admin.py:151 jdav_web/mailer/tests/admin.py:146
msgid "Successfully sent message"
msgstr "Email wurde erfolgreich verschickt"

#: jdav_web/mailer/apps.py:7
msgid "mailer"
msgstr "Verteiler"

#: jdav_web/mailer/management/commands/notify_active.py:38
#, python-format
msgid "Congratulation %(name)s"
msgstr "Herzlichen Glückwunsch %(name)s"

#: jdav_web/mailer/models.py:27
msgid "Only alphanumeric characters, ., - and _ are allowed"
msgstr "Nur Buchstaben, Zahlen, ., . und _ sind erlaubt"

#: jdav_web/mailer/models.py:34
msgid "name"
msgstr "Name"

#: jdav_web/mailer/models.py:36
msgid "external email address"
msgstr "Externe E-Mail-Adresse"

#: jdav_web/mailer/models.py:39
msgid ""
"Set this to an arbitrary external email address. No forwarding happens for "
"external email addresses; forwarding fields (participants, groups) must be "
"left empty."
msgstr ""
"Hier kann eine beliebige externe E-Mail-Adresse eingetragen werden. Für "
"externe E-Mail-Adressen findet keine Weiterleitung statt; die "
"Weiterleitungsfelder (Teilnehmer*innen, Gruppen) müssen leer bleiben."

#: jdav_web/mailer/models.py:45
msgid "Forward to participants"
msgstr "Weiterleitung an Teilnehmer*innen"

#: jdav_web/mailer/models.py:48
msgid "Forward to group"
msgstr "Weiterleitung an Gruppe"

#: jdav_web/mailer/models.py:51
msgid "Restrict to internal email addresses"
msgstr "Weiterleitung nur von internen E-Mail Adressen erlaubt"

#: jdav_web/mailer/models.py:53
#, python-format
msgid ""
"Only allow forwarding to this e-mail address from one of the following "
"domains: %(domains)s."
msgstr ""
"Leite nur E-Mails weiter, die von einer der folgenden Domains verschickt "
"wurden: %(domains)s."

#: jdav_web/mailer/models.py:60
msgid "Allowed sender"
msgstr "Erlaubte Absender:innen"

#: jdav_web/mailer/models.py:62
msgid ""
"Only forward e-mails of members of selected groups. Leave empty to allow all "
"senders."
msgstr ""
"Leite nur E-Mails von Mitgliedern dieser Gruppen weiter. Lasse dieses Feld "
"frei, um alle Absender*innen zu erlauben."

#: jdav_web/mailer/models.py:86
msgid "email address"
msgstr "Email-Adresse"

#: jdav_web/mailer/models.py:87
msgid "email addresses"
msgstr "Email-Adressen"

#: jdav_web/mailer/models.py:104
msgid ""
"No forwarding happens for external email addresses. Please leave the "
"forwarding fields (participants, groups) empty."
msgstr ""
"Für externe E-Mail-Adressen findet keine Weiterleitung statt. Bitte die "
"Weiterleitungsfelder (Teilnehmer*innen, Gruppen) leer lassen."

#: jdav_web/mailer/models.py:111
msgid "Either a group or at least one member is required as forward recipient."
msgstr ""
"Es muss entweder eine Gruppe oder mindestens ein*e Teilnehmer*in als "
"Empfänger*in ausgewählt werden."

